{$SITE_DOMAIN} {
	encode zstd gzip

	header {
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	# Prometheus 只透過 Docker 內網直接抓取 api:8000/metrics；不得從公開 /api 暴露。
	@public_metrics path /api/metrics
	respond @public_metrics 404

	handle_path /api/* {
		reverse_proxy api:8000 {
			health_uri /ready
			health_interval 15s
			health_timeout 3s
		}
	}

	handle /ws/* {
		reverse_proxy api:8000
	}

	# 使用者上傳檔案（公告圖、問卷圖等公開素材）：快取 1 天
	handle /uploads/* {
		header Cache-Control "public, max-age=86400"
		reverse_proxy api:8000
	}

	handle /auth/google/* {
		reverse_proxy api:8000
	}

	# Next.js 靜態資源（hashed 檔名，永久快取）
	handle /_next/static/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy web:3000
	}

	handle {
		reverse_proxy web:3000
	}
}
