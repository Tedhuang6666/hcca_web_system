{
	# 僅接受 Cloudflare 已驗證來源提供的 client IP，避免偽造 CF-Connecting-IP。
	servers {
		trusted_proxies cloudflare
	}
}

{$SITE_DOMAIN} {
	encode zstd gzip

	header {
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	# Prometheus 只透過 Docker 內網直接抓取 api:8000/metrics；不得從公開 /api 暴露。
	@public_metrics path /api/metrics
	respond @public_metrics 404

	handle_path /api/* {
		reverse_proxy api:8000 {
			header_up CF-Connecting-IP {client_ip}
			health_uri /ready
			health_interval 15s
			health_timeout 3s
		}
	}

	# 異地主機的 Discord Bot 只需要這組內部 API；路由本身仍由 FastAPI
	# 的 X-API-Key + discord:bot scope 保護，不把整個 API 面暴露給 Bot。
	handle /internal/discord/* {
		reverse_proxy api:8000 {
			header_up CF-Connecting-IP {client_ip}
			health_uri /ready
			health_interval 15s
			health_timeout 3s
		}
	}

	handle /ws/* {
		reverse_proxy api:8000 {
			header_up CF-Connecting-IP {client_ip}
		}
	}

	# 使用者上傳檔案（公告圖、問卷圖等公開素材）：快取 1 天
	# 財務憑證必須通過 /api/finance/journals/{id}/evidence 的帳本權限檢查，
	# 不可由靜態 uploads 路徑繞過。
	@private_finance_evidence path /uploads/finance/evidence/*
	respond @private_finance_evidence 404

	handle /uploads/* {
		header Cache-Control "public, max-age=86400"
		reverse_proxy api:8000
	}

	handle /auth/google/* {
		reverse_proxy api:8000
	}

	# Next.js 靜態資源（hashed 檔名，永久快取）
	handle /_next/static/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy web:3000
	}

	handle {
		reverse_proxy web:3000
	}
}
