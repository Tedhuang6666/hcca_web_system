<mjml>
  <mj-head>
    <mj-include path="./_head.mjml" />
    <mj-title>{{ subject }}</mj-title>
    <mj-preview>{{ preview_text }}</mj-preview>
  </mj-head>
  <mj-body background-color="#eef2f7">
    <mj-include path="./_header.mjml" />
    <mj-section background-color="#eef2f7" padding="24px 18px 28px">
      <mj-column>
        <mj-text padding="0">
          <div style="background-color:#ffffff;border:1px solid #e5e7eb;border-radius:24px;padding:32px 30px 30px;box-shadow:0 14px 34px rgba(15,23,42,.08);">
            <div class="hcca-kicker" style="margin-bottom:10px;">Official Message</div>
            <div style="color:#111827;font-size:26px;font-weight:850;line-height:1.32;margin-bottom:22px;">{{ heading or subject }}</div>
            {% if banner_image_url %}
              <div style="padding:0 0 22px;text-align:center;"><img src="{{ banner_image_url }}" alt="{{ banner_image_alt }}" width="540" style="display:block;max-width:100%;height:auto;border-radius:16px;" /></div>
            {% endif %}
            {% if card_rows %}
              <div style="margin:0 0 22px;">
                {% for row in card_rows %}
                  {% if loop.first %}
                    <div style="background:#fff4c7;border-radius:20px;padding:22px 22px 24px;margin:0 0 12px;">
                      <div class="hcca-highlight-label">{{ row.label }}</div>
                      <div class="hcca-highlight-value">{{ row.value }}</div>
                    </div>
                  {% else %}
                    <div style="background:#f4f7fb;border-radius:16px;padding:15px 18px;margin:0 0 10px;">
                      <div class="hcca-note-label">{{ row.label }}</div>
                      <div class="hcca-note-value">{{ row.value }}</div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
            <div class="hcca-body">{{ body_html | safe }}</div>
            {% for blk in blocks %}
              {% if blk.type == 'image' %}
                <div style="padding:18px 0 0;text-align:center;"><img src="{{ blk.url }}" alt="{{ blk.alt }}" width="540" style="max-width:100%;height:auto;border-radius:14px;" /></div>
              {% elif blk.type == 'divider' %}
                <div style="border-top:1px solid #e5e7eb;margin:22px 0;"></div>
              {% elif blk.type == 'text' %}
                <div class="hcca-body" style="padding-top:6px;">{{ blk.html | safe }}</div>
              {% endif %}
            {% endfor %}
            {% if buttons %}
              <div style="padding:24px 0 0;">
                {% for b in buttons %}
                  <a href="{{ b.url }}" style="box-sizing:border-box;display:inline-block;margin:0 10px 10px 0;max-width:100%;font-size:15px;font-weight:800;text-decoration:none;padding:14px 28px;border-radius:12px;word-break:break-word;{% if b.style == 'secondary' %}background-color:#d6b34a;color:#111827;{% elif b.style == 'outline' %}background-color:#ffffff;color:#111827;border:1px solid #111827;{% else %}background-color:#111827;color:#ffffff;{% endif %}">{{ b.label or '查看詳情' }}</a>
                {% endfor %}
              </div>
            {% elif cta_url %}
              <div style="padding:24px 0 0;">
                <a href="{{ cta_url }}" style="box-sizing:border-box;display:inline-block;max-width:100%;background-color:#111827;color:#ffffff;font-size:15px;font-weight:800;text-decoration:none;padding:14px 28px;border-radius:12px;word-break:break-word;">{{ cta_label or '查看詳情' }}</a>
              </div>
            {% endif %}
          </div>
        </mj-text>
      </mj-column>
    </mj-section>
    <mj-include path="./_footer.mjml" />
  </mj-body>
</mjml>
