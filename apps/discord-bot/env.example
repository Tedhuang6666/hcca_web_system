# Bot host only. Do not copy the API host's database or Redis credentials here.
# The value must be the public HTTPS origin that routes /internal/discord/* to FastAPI.
HCCA_DISCORD_BOT_API_URL=https://api.example.edu.tw
HCCA_DISCORD_BOT_API_KEY=hcca_replace_with_one_time_key

# Optional Cloudflare Access service token, only when the API route is protected by Access.
HCCA_DISCORD_BOT_CF_ACCESS_CLIENT_ID=
HCCA_DISCORD_BOT_CF_ACCESS_CLIENT_SECRET=

# Used when the bot creates links back to the web application.
FRONTEND_BASE_URL=https://platform.example.edu.tw

DISCORD_BOT_TOKEN=replace_with_discord_bot_token
DISCORD_GUILD_ID=
# Set this to a test guild for immediate slash-command sync; leave empty for global sync.
DISCORD_COMMAND_SYNC_GUILD_ID=
