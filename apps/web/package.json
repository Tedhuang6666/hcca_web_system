{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build --webpack",
    "start": "next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js",
