    "@tiptap/extension-underline": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@types/qrcode": "^1.5.6",
    "cmdk": "^1.1.1",
    "diff": "^9.0.0",
    "dompurify": "^3.4.10",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "pdfjs-dist": "^6.1.200",
    "posthog-js": "^1.404.1",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
