# ============================================================
# 校園自治整合平台 - 環境變數範例
# 複製此檔案為 .env 並填入實際數值
# ============================================================

# --- 應用程式 ---
APP_NAME=校園自治整合平台
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000"]

# --- 資料庫 ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/campus_platform
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/campus_platform

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT 安全金鑰 (請使用 256-bit 隨機字串) ---
# 產生指令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=3a221e2fe782683f85ac4826cfafb91c0495618e853b1a45e958b06823ad0ee0
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth2 ---
# 至 https://console.cloud.google.com/ 建立 OAuth2 用戶端
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
