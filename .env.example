# ============================================================
# 校園自治整合平台 - 環境變數範例
# 複製此檔案為 .env 並填入實際數值
# ============================================================

# --- 應用程式 ---
APP_NAME=新竹高中班聯會 HCCA 校園自治整合平台
ENVIRONMENT=development
DEBUG=true
ENABLE_API_DOCS=true
SQL_ECHO=false
ALLOWED_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1","api"]
LOG_LEVEL=INFO
# dev 建議 text（一行可讀）；prod 改 json 給 Grafana/ELK 吃
LOG_FORMAT=text
ACCESS_LOG_ENABLED=true

# --- 前端 ---
# 瀏覽器呼叫後端 API 的公開位址；留空時使用同源 /api 代理，適合 VS Code port forwarding
NEXT_PUBLIC_API_URL=
# 瀏覽器連線後端 WebSocket 的公開位址；本機開發預設 FastAPI 8000 port
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# 前端公開網址；社群分享 Open Graph / canonical URL 使用
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Next.js 伺服器端轉發到 FastAPI 的內部位址；Docker Compose 使用 http://api:8000
API_INTERNAL_URL=http://localhost:8000

# --- 資料庫 ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/campus_platform
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/campus_platform
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
HEALTHCHECK_TIMEOUT_SECONDS=2
SLOW_REQUEST_THRESHOLD_MS=1000

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=2.0
REDIS_HEALTH_CHECK_INTERVAL=30

# --- Celery 失敗留存 / Dead Letter ---
CELERY_DLQ_ENABLED=true
CELERY_DLQ_REDIS_KEY=celery:dead_letter:v1
CELERY_DLQ_MAX_ITEMS=1000

# --- Cloudflare / 信任代理 ---
# 部署在 Cloudflare 後面時開啟；中介層會從 CF-Connecting-IP 取真實 client IP，
# 並僅在 socket peer ∈ Cloudflare 官方 CIDR 時信任（防止偽造）。
TRUST_CLOUDFLARE_PROXY=false
# 留空時內建 CF 官方公開清單；測試環境可填 ["127.0.0.1/32"]
CF_TRUSTED_PROXIES=[]

# --- WebSocket 連線控制 ---
WS_GLOBAL_MAX_CONNECTIONS=2000
WS_PER_IP_MAX_CONNECTIONS=20
WS_PER_ROOM_MAX_CONNECTIONS=300
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_HEARTBEAT_TIMEOUT_SECONDS=90

# --- Payload 大小上限（middleware 粗篩） ---
# JSON 等一般 body 2 MiB；multipart 檔案上傳 25 MiB（再由 storage.py 做檔案層級檢查）
PAYLOAD_MAX_BYTES_JSON=2097152
PAYLOAD_MAX_BYTES_MULTIPART=26214400

# --- Sentry 錯誤追蹤（留空則停用） ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# --- WebSocket pub/sub backend（多 worker / 多節點需要 redis） ---
WS_PUBSUB_BACKEND=redis

# --- Load Shedding（管理員優先） ---
LOAD_SHED_ENABLED=true
LOAD_SHED_MAX_ACTIVE_REQUESTS=100
LOAD_SHED_5XX_RATIO_THRESHOLD=0.10
LOAD_SHED_DB_POOL_THRESHOLD=0.85
LOAD_SHED_RETRY_AFTER_BASE_SECONDS=5

# --- 模組斷路器（per-module 自動維護） ---
MODULE_CIRCUIT_ENABLED=true
MODULE_CIRCUIT_5XX_THRESHOLD=10
MODULE_CIRCUIT_WINDOW_SECONDS=60
MODULE_CIRCUIT_COOLDOWN_SECONDS=120

# --- 模組斷路器：升級門檻（依錯誤嚴重度）---
# 1h 內跳閘次數達門檻 → 升級為 manual 維護（不自動恢復，需管理員介入）
MODULE_TRIP_THRESHOLD_CRITICAL=3
MODULE_TRIP_THRESHOLD_HIGH=5
MODULE_TRIP_THRESHOLD_NORMAL=7
MODULE_TRIP_ESCALATION_WINDOW_SECONDS=3600
# 自動跳閘 cooldown 指數退避：base × 2^(count-1)，封頂 MAX
MODULE_CIRCUIT_COOLDOWN_BASE_SECONDS=60
MODULE_CIRCUIT_COOLDOWN_MAX_SECONDS=1800
# half-open 探測排程（每幾秒掃 Redis ZSET 嘗試恢復）
MODULE_PROBE_INTERVAL_SECONDS=30
# 模組探測使用的內部 base URL。探測在 celery-worker 容器內執行（非 API 自身），
# 必須指向 docker 網路內的 api 服務；用 127.0.0.1 會打到 worker 自己 → 探測永遠失敗、
# 跳閘模組無法自動恢復。與 API_INTERNAL_URL 一致。
MODULE_PROBE_BASE_URL=http://api:8000
# 跳閘通知 Discord 頻道 ID（留空則不發 Discord）
MODULE_ALERT_DISCORD_CHANNEL_ID=

# --- 系統設定 / .env 編輯頁（高危：預設關閉） ---
# 啟用後超管可於 /admin/settings 檢視與編輯設定；明文密鑰與儲存均須再次通過 MFA TOTP。
# 因為集中曝險所有設定值，僅在維運必要時短暫開啟，使用完再關閉。
ENABLE_ENV_EDITOR=false

# --- Admin 通道（docker-compose 的 api-admin service） ---
ADMIN_GUNICORN_WORKERS=2
ADMIN_DB_POOL_SIZE=5
ADMIN_DB_MAX_OVERFLOW=5

# --- Celery Flower 監控介面（http://localhost:5555/flower） ---
FLOWER_USER=admin
FLOWER_PASSWORD=changeme

# --- PostHog 產品分析（留空則停用；敏感頁面請避免啟用 session replay） ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Meilisearch 全站搜尋（留空則使用資料庫 fallback） ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX_PREFIX=hcca

# --- Web Push / PWA 推播 ---
# 可用 pywebpush / web-push CLI 產生 VAPID key pair
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Passkeys / WebAuthn ---
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=HCCA 校園自治整合平台
PASSKEY_ORIGIN=http://localhost:3000

# --- JWT 安全金鑰 (請使用 256-bit 隨機字串) ---
# 產生指令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_SECURE_256BIT_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_COOKIE_NAME=hcca_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Google OAuth2 ---
# 至 https://console.cloud.google.com/ 建立 OAuth2 用戶端
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Google One Tap 前端使用；通常與 GOOGLE_CLIENT_ID 相同
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# 預設只允許 LOGIN_ALLOWED_EMAIL_DOMAINS / LOGIN_EMAIL_ALLOWLIST 登入。
# 若臨時需要開放校外帳號進入公開檢視層級，可改為 true。
LOGIN_ALLOW_EXTERNAL_USERS=false
# 下列兩項僅在 LOGIN_ALLOW_EXTERNAL_USERS=false 時生效：限定校內網域與例外名單。
LOGIN_ALLOWED_EMAIL_DOMAINS=["hchs.hc.edu.tw"]
LOGIN_EMAIL_ALLOWLIST=[]

# --- Email / Resend ---
RESEND_API_KEY=re_xxxxxxxxx
MAIL_FROM=noreply@hct.works
MAIL_FROM_NAME=新竹高中班聯會 HCCA
# 前端基底 URL — email 內絕對連結用（退訂連結、CTA、通知偏好頁）
FRONTEND_BASE_URL=http://localhost:3000
API_PUBLIC_BASE_URL=http://localhost:8000
EMAIL_LINK_BASE_URL=https://hcca40.hct.works
# 外部圖床完整網址；此 host 須同步列入 proxy.ts 與 config.py 的 CSP img-src 白名單，
# 否則寄信頁預覽 iframe 會被 CSP 擋下。
EMAIL_BRAND_LOGO_URL=https://hcca.buckets.hct.works/images/hcca-emblem.png
# 每位使用者每日透過平台寄送 email 的「人次」上限（防濫用）
EMAIL_DAILY_QUOTA_PER_USER=500
EMAIL_ATTACHMENT_INLINE_MAX_BYTES=8388608
EMAIL_ATTACHMENT_LINK_EXPIRES_SECONDS=604800
EMAIL_SEND_BATCH_SIZE=100
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx

# --- LINE Bot ---
# 至 https://developers.line.biz/ 建立 Messaging API Channel
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# Discord Bot / OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=http://localhost:8000/discord/callback
DISCORD_GUILD_ID=
DISCORD_COMMAND_SYNC_GUILD_ID=

# --- 速率限制 ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
# 自己人 IP 白名單（逗號分隔，支援 CIDR）：豁免 rate limit 與 IP 黑名單（含 WAF autoblock）。
# 填你的家用 / 辦公室固定 IP 與 127.0.0.1，避免自己被自家防護鎖在門外。留空＝關閉。
RATE_LIMIT_TRUSTED_IPS=127.0.0.1
# 主動弱掃繞過 token：掃描時帶 header `X-Security-Scan: <此值>` 即可完全繞過 WAF /
# rate limit / IP 黑名單。須 >= 16 字元；留空＝停用。請用 `openssl rand -hex 32` 產生。
SECURITY_SCAN_BYPASS_TOKEN=

# --- Idempotency（防重複送出；客戶端需帶 Idempotency-Key） ---
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_LOCK_TTL_SECONDS=30
IDEMPOTENCY_METHODS=["POST","PUT","PATCH"]

# --- Worker / 容量設定 ---
GUNICORN_WORKERS=4
GUNICORN_KEEPALIVE=5
GUNICORN_TIMEOUT=60
CELERY_WORKER_CONCURRENCY=4
CELERY_DB_POOL_SIZE=5
CELERY_DB_MAX_OVERFLOW=10
CELERY_BEAT_DB_POOL_SIZE=2
CELERY_BEAT_DB_MAX_OVERFLOW=2

# --- 自動錯誤報告（寄給 OWNER_EMAILS）---
ERROR_REPORT_EMAIL_ENABLED=true
ERROR_REPORT_INTERVAL_SECONDS=300
ERROR_REPORT_WINDOW_SECONDS=900
ERROR_REPORT_MAX_ITEMS=20
ERROR_REPORT_REDIS_KEY=error_report:events:v1
ERROR_REPORT_STATE_KEY=error_report:last_sent_at:v1
ERROR_REPORT_RETENTION_ITEMS=1000

# --- 超級管理員（僅開發/測試環境）---
# OWNER_EMAILS=["owner@gmail.com"]
# 注意：生產環境 (ENVIRONMENT=production) 設定此項會導致啟動失敗
# SUPERUSER_EMAILS=["admin@example.edu"]
