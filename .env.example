# ============================================================
# 校園自治整合平台 - 環境變數範例
# 複製此檔案為 .env 並填入實際數值
# ============================================================

# --- 應用程式 ---
APP_NAME=校園自治整合平台
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000"]

# --- 前端 ---
# 瀏覽器呼叫後端 API 的公開位址（用於 Docker 建置；本機開發預設為 http://localhost:8000）
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- 資料庫 ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/campus_platform
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/campus_platform

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT 安全金鑰 (請使用 256-bit 隨機字串) ---
# 產生指令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_SECURE_256BIT_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Google OAuth2 ---
# 至 https://console.cloud.google.com/ 建立 OAuth2 用戶端
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Email / SMTP (以 Gmail 為例) ---
# Gmail 需開啟「應用程式密碼」: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@example.com
MAIL_FROM_NAME=校園自治整合平台
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# --- LINE Bot ---
# 至 https://developers.line.biz/ 建立 Messaging API Channel
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# --- 速率限制 ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- 超級管理員（僅開發/測試環境）---
# 注意：生產環境 (ENVIRONMENT=production) 設定此項會導致啟動失敗
# SUPERUSER_EMAILS=["admin@example.edu"]
