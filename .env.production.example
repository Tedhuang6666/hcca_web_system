# ============================================================
# 校園自治整合平台 - 生產環境變數範例
# 複製為 .env.production，填入實際值後使用：
# docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
#
# 說明：docker-compose.prod.yml 透過 env_file 載入整份檔案，
#       DATABASE_URL / REDIS_URL / 連線池大小由 compose 從 POSTGRES_* / REDIS_PASSWORD
#       自動組出，故此處不需（也不應）重複設定。其餘欄位會原樣注入容器。
# ============================================================

# --- 部署網域 ---
SITE_DOMAIN=hcca40.hct.works

# --- 應用程式 ---
APP_NAME=新竹高中班聯會 HCCA 校園自治整合平台
ENVIRONMENT=production
DEBUG=false
ENABLE_API_DOCS=false
SQL_ECHO=false
ALLOWED_ORIGINS=["https://hcca40.hct.works"]
ALLOWED_HOSTS=["hcca40.hct.works","localhost","127.0.0.1","api","api-blue","api-green","web","web-blue","web-green"]
LOG_LEVEL=INFO
# prod 用 json 給 Grafana/ELK 吃；dev 才用 text
LOG_FORMAT=json
ACCESS_LOG_ENABLED=true

# --- 前端 ---
# 留空代表瀏覽器使用同源 /api，由 Next.js 轉發到 API。
NEXT_PUBLIC_API_URL=
# 留空代表瀏覽器使用同網域 /ws，由 Caddy 直接轉發到 API。
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_SITE_URL=https://hcca40.hct.works
FRONTEND_BASE_URL=https://hcca40.hct.works
API_INTERNAL_URL=http://api:8000

# --- 資料庫 ---
# DATABASE_URL / DATABASE_URL_SYNC 由 docker-compose.prod.yml 從下列 POSTGRES_* 組出。
POSTGRES_USER=hcca
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_DATABASE_PASSWORD
POSTGRES_DB=campus_platform
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
HEALTHCHECK_TIMEOUT_SECONDS=2
SLOW_REQUEST_THRESHOLD_MS=1000

# --- Redis ---
# REDIS_URL 由 docker-compose.prod.yml 從 REDIS_PASSWORD 組出（redis://:PASS@redis:6379/0）。
REDIS_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_REDIS_PASSWORD
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=2.0
REDIS_HEALTH_CHECK_INTERVAL=30

# --- Celery 失敗留存 / Dead Letter ---
CELERY_DLQ_ENABLED=true
CELERY_DLQ_REDIS_KEY=celery:dead_letter:v1
CELERY_DLQ_MAX_ITEMS=1000

# --- 資料庫備份 / 復原 ---
# Celery beat 每日 03:00 排程 pg_dump；備份檔會寫入 docker volume 的 /app/backups。
DB_BACKUP_ENABLED=true
DB_BACKUP_DIR=/app/backups
DB_BACKUP_RETENTION_DAYS=30
# 建議正式環境設定，備份會以 GPG 對稱加密並寫入 sha256 紀錄。
BACKUP_GPG_PASSPHRASE=CHANGE_ME_TO_A_LONG_RANDOM_BACKUP_PASSPHRASE
BACKUP_VERIFY_SHA256=true

# --- Cloudflare / 信任代理 ---
# 部署在 Cloudflare 後面時開啟；中介層會從 CF-Connecting-IP 取真實 client IP，
# 並僅在 socket peer ∈ Cloudflare 官方 CIDR 時信任（防止偽造）。
# 若只用 Caddy 直接對外（非 Cloudflare），維持 false。
TRUST_CLOUDFLARE_PROXY=false
# 留空時內建 CF 官方公開清單。
CF_TRUSTED_PROXIES=[]

# --- WebSocket 連線控制 ---
WS_GLOBAL_MAX_CONNECTIONS=2000
WS_PER_IP_MAX_CONNECTIONS=20
WS_PER_ROOM_MAX_CONNECTIONS=300
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_HEARTBEAT_TIMEOUT_SECONDS=90
# 多 worker / 多節點時必須用 redis 廣播，否則跨 worker 收不到對方訊息。
WS_PUBSUB_BACKEND=redis

# --- Payload 大小上限（middleware 粗篩） ---
# JSON 等一般 body 2 MiB；multipart 檔案上傳 25 MiB（再由 storage.py 做檔案層級檢查）
PAYLOAD_MAX_BYTES_JSON=2097152
PAYLOAD_MAX_BYTES_MULTIPART=26214400

# --- Sentry 錯誤追蹤（留空則停用） ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05

# --- Load Shedding（管理員優先） ---
LOAD_SHED_ENABLED=true
LOAD_SHED_MAX_ACTIVE_REQUESTS=100
LOAD_SHED_5XX_RATIO_THRESHOLD=0.10
LOAD_SHED_DB_POOL_THRESHOLD=0.85
LOAD_SHED_RETRY_AFTER_BASE_SECONDS=5

# --- 模組斷路器（per-module 自動維護） ---
MODULE_CIRCUIT_ENABLED=true
MODULE_CIRCUIT_5XX_THRESHOLD=10
MODULE_CIRCUIT_WINDOW_SECONDS=60
MODULE_CIRCUIT_COOLDOWN_SECONDS=120

# --- 模組斷路器：升級門檻（依錯誤嚴重度）---
# 1h 內跳閘次數達門檻 → 升級為 manual 維護（不自動恢復，需管理員介入）
MODULE_TRIP_THRESHOLD_CRITICAL=3
MODULE_TRIP_THRESHOLD_HIGH=5
MODULE_TRIP_THRESHOLD_NORMAL=7
MODULE_TRIP_ESCALATION_WINDOW_SECONDS=3600
# 自動跳閘 cooldown 指數退避：base × 2^(count-1)，封頂 MAX
MODULE_CIRCUIT_COOLDOWN_BASE_SECONDS=60
MODULE_CIRCUIT_COOLDOWN_MAX_SECONDS=1800
# half-open 探測排程（每幾秒掃 Redis ZSET 嘗試恢復）
MODULE_PROBE_INTERVAL_SECONDS=30
# 模組探測使用的內部 base URL（self loopback）
MODULE_PROBE_BASE_URL=http://127.0.0.1:8000
# 跳閘通知 Discord 頻道 ID（留空則不發 Discord）
MODULE_ALERT_DISCORD_CHANNEL_ID=

# --- 系統設定 / .env 編輯頁（高危：預設關閉） ---
# 啟用後超管可於 /admin/settings 檢視與編輯設定；明文密鑰與儲存均須再次通過 MFA TOTP。
# 因為集中曝險所有設定值，僅在維運必要時短暫開啟，使用完再關閉。
ENABLE_ENV_EDITOR=false

# --- JWT / Cookie ---
# 產生指令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_SECURE_256BIT_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_COOKIE_NAME=hcca_session
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Google One Tap 前端使用；通常與 GOOGLE_CLIENT_ID 相同
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://hcca40.hct.works/auth/google/callback
LOGIN_ALLOW_EXTERNAL_USERS=false
LOGIN_ALLOWED_EMAIL_DOMAINS=["hchs.hc.edu.tw"]
LOGIN_EMAIL_ALLOWLIST=[]

# --- Email / Resend ---
RESEND_API_KEY=re_xxxxxxxxx
MAIL_FROM=noreply@hct.works
MAIL_FROM_NAME=新竹高中班聯會 HCCA
# 每位使用者每日透過平台寄送 email 的「人次」上限（防濫用）
EMAIL_DAILY_QUOTA_PER_USER=500

# --- LINE Bot ---
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# Discord Bot / OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=https://hcca40.hct.works/discord/callback
DISCORD_GUILD_ID=
DISCORD_COMMAND_SYNC_GUILD_ID=

# --- Passkeys / WebAuthn ---
PASSKEY_RP_ID=hcca40.hct.works
PASSKEY_RP_NAME=HCCA 校園自治整合平台
PASSKEY_ORIGIN=https://hcca40.hct.works

# --- Web Push / PWA 推播 ---
# 可用 pywebpush / web-push CLI 產生 VAPID key pair
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hcca@hct.works

# --- PostHog 產品分析（留空則停用；敏感頁面請避免啟用 session replay） ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Meilisearch 全站搜尋（留空則使用資料庫 fallback） ---
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX_PREFIX=hcca

# --- Celery Flower 監控介面 ---
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_TO_A_STRONG_FLOWER_PASSWORD

# --- 速率限制 ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- Idempotency（防重複送出；客戶端需帶 Idempotency-Key） ---
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_LOCK_TTL_SECONDS=30
IDEMPOTENCY_METHODS=["POST","PUT","PATCH"]

# --- Worker / 容量設定 ---
# 並發數依主機核數調整。小型單核機（如 1 vCPU / 2GB）建議 2，避免互搶單核並吃爆 RAM 觸發 OOM。
# 多核機可調高（gunicorn 通用公式 2×核數+1）。
GUNICORN_WORKERS=2
GUNICORN_KEEPALIVE=5
GUNICORN_TIMEOUT=60
CELERY_WORKER_CONCURRENCY=2
# 每個 child 跑滿幾個 task 後回收，防止記憶體洩漏累積。
CELERY_MAX_TASKS_PER_CHILD=200
CELERY_DB_POOL_SIZE=5
CELERY_DB_MAX_OVERFLOW=10
CELERY_BEAT_DB_POOL_SIZE=2
CELERY_BEAT_DB_MAX_OVERFLOW=2

# --- 容器資源護欄（docker-compose.prod.yml mem_limit / cpus 的覆寫值）---
# 全部有預設值，留空即用 compose 內建。預設針對 4GB / 2-4 核 VPS 調校。
# celery 子進程記憶體上限（KB）：超過此值，做完當前 task 優雅重啟 child，趕在被 OOM 前自救。
CELERY_MAX_MEMORY_PER_CHILD_KB=450000
# celery-worker 容器硬上限（同時設成 memswap_limit = 禁用 swap，失控只砍自己）。
CELERY_WORKER_MEM_LIMIT=1200m
CELERY_WORKER_CPUS=1.5
CELERY_BEAT_MEM_LIMIT=256m
CELERY_BEAT_CPUS=0.25
DB_MEM_LIMIT=768m
DB_CPUS=1.5
REDIS_MEM_LIMIT=256m
REDIS_CPUS=0.5
API_MEM_LIMIT=1024m
API_CPUS=2
WEB_MEM_LIMIT=512m
WEB_CPUS=1
PROXY_MEM_LIMIT=128m
PROXY_CPUS=0.5

# --- 啟動彈性 ---
# 啟動時等 DB / Redis 就緒的總上限秒數（退避重試）；逾時才讓 app exit。
# 設 >0 可避免資源緊張時 DB 短暫變慢就 crash-loop flapping。
STARTUP_READINESS_MAX_WAIT_SECONDS=60

# --- PgBouncer 連線池（Phase D；預設關閉）---
# 啟用：取消下面三行註解，重啟後 api/celery 經 PgBouncer 連 DB（migration 仍直連 db）。
# 上線前務必照 Phase D 驗證 auth 與 SHOW POOLS / pg_stat_activity。
# DB_USE_PGBOUNCER=true
# DB_HOST=pgbouncer
# DB_PORT=6432
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_MEM_LIMIT=64m
PGBOUNCER_CPUS=0.25

# --- Admin 通道（docker-compose 的 api-admin service；prod.yml 未起則可忽略） ---
ADMIN_GUNICORN_WORKERS=2
ADMIN_DB_POOL_SIZE=5
ADMIN_DB_MAX_OVERFLOW=5

# 擁有者帳號不可由後台停用或降級；請放正式維運者帳號。
OWNER_EMAILS=[]
# 生產環境不可設定 SUPERUSER_EMAILS。
