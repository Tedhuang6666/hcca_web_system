# ============================================================
# 校園自治整合平台 - 生產環境變數範例
# 複製為 .env.production，填入實際值後使用：
# docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
# ============================================================

# --- 部署網域 ---
SITE_DOMAIN=example.edu.tw

# --- 應用程式 ---
APP_NAME=校園自治整合平台
ENVIRONMENT=production
DEBUG=false
ENABLE_API_DOCS=false
SQL_ECHO=false
ALLOWED_ORIGINS=["https://example.edu.tw"]
ALLOWED_HOSTS=["example.edu.tw","web","api"]

# --- 前端 ---
# 留空代表瀏覽器使用同源 /api，由 Next.js 轉發到 API。
NEXT_PUBLIC_API_URL=
# 留空代表瀏覽器使用同網域 /ws，由 Caddy 直接轉發到 API。
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_SITE_URL=https://example.edu.tw
FRONTEND_BASE_URL=https://example.edu.tw
API_INTERNAL_URL=http://api:8000

# --- 資料庫 ---
POSTGRES_USER=hcca
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_DATABASE_PASSWORD
POSTGRES_DB=campus_platform

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_REDIS_PASSWORD

# --- JWT / Cookie ---
# 產生指令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_SECURE_256BIT_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_COOKIE_NAME=hcca_session
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://example.edu.tw/auth/google/callback
LOGIN_ALLOW_EXTERNAL_USERS=false
LOGIN_ALLOWED_EMAIL_DOMAINS=["hchs.hc.edu.tw"]
LOGIN_EMAIL_ALLOWLIST=[]

# --- Email / SMTP ---
MAIL_USERNAME=your-email@example.edu.tw
MAIL_PASSWORD=your-smtp-app-password
MAIL_FROM=your-email@example.edu.tw
MAIL_FROM_NAME=校園自治整合平台
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# --- LINE Bot ---
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# --- 速率限制 ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- Worker ---
GUNICORN_WORKERS=4
CELERY_WORKER_CONCURRENCY=4

# 擁有者帳號不可由後台停用或降級；請放正式維運者帳號。
OWNER_EMAILS=[]
# 生產環境不可設定 SUPERUSER_EMAILS。
